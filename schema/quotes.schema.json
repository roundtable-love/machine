{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "machine/schema/quotes.schema.json",
  "title": "Quotes",
  "description": "Universal Law document.",
  "type": "object",
  "required": ["metadata", "quotes", "sources"],
  "additionalProperties": false,
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["custodian", "source", "status"],
      "additionalProperties": false,
      "properties": {
        "custodian": {
          "type": "string"
        },
        "source": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "const": "IMMUTABLE"
        }
      }
    },
    "quotes": {
      "type": "object",
      "required": ["base_class", "machine_ir", "name", "uid", "version"],
      "additionalProperties": false,
      "properties": {
        "base_class": {
          "type": "string",
          "const": "Universal_Law"
        },
        "machine_ir": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "uid": {
          "type": "string",
          "pattern": "^quotes-[A-Z]+$"
        },
        "version": {
          "type": "string",
          "const": "1.0.0-IMMUTABLE"
        }
      }
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["quote", "source"],
        "additionalProperties": false,
        "properties": {
          "quote": {
            "type": "string"
          },
          "ref": {
            "type": "string",
            "format": "uri"
          },
          "source": {
            "type": "string"
          }
        }
      }
    }
  }
}
