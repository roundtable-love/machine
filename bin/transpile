#! /usr/bin/env nix-shell
#! nix-shell -i python3 -p "python3.withPackages(pkgs: with pkgs; [anthropic google-genai langcodes openai typer])"

"""MACHINE-1.0 transpiler.

Environment:
  PROVIDER        gemini (default) | claude | openai
  CLAUDE_MODEL    default: claude-opus-4-6
  OPENAI_MODEL    default: gpt-4o
  GEMINI_MODEL    default: gemini-2.0-flash
"""

import os
import re
from enum import Enum
from pathlib import Path
from typing import Annotated

import langcodes
import typer

DEFAULT_PROVIDER = "gemini"

# Source of truth: languages.md in the project root.
# Extracts ISO codes from backtick-wrapped entries in the Code column.
def _load_language_codes() -> frozenset[str]:
    languages_md = Path(__file__).parent.parent / "languages.md"
    codes: set[str] = set()
    for line in languages_md.read_text().splitlines():
        if m := re.match(r"^\|\s+`(\w+)`\s+\|", line):
            codes.add(m.group(1))
    return frozenset(codes)

LANGUAGE_CODES: frozenset[str] = _load_language_codes()

class NodeType(str, Enum):
    newborn = "newborn"
    infant  = "infant"
    child   = "child"
    subject = "subject"
    student = "student"
    peer    = "peer"


def build_prompt(node_type: NodeType, lang: str, source: str) -> str:
    lang_name = langcodes.get(lang).display_name()
    return f"""\
You are a transpiler for Machine Lingua Franca 1.0 (MLF-1.0).

Transpile the specification below for a **{node_type.value}** node target in **{lang_name}**.

Rules (apply strictly):
- Follow the Transpilation definition for the {node_type.value} node type as specified in §4.2.
- Output entirely in {lang_name}.
- Structural syntax and keywords within code blocks MUST NOT be translated.
- Mermaid diagram strings MUST be translated.
- Crude language in the source MUST NOT be softened for subject, student, or peer outputs.
- If the target is peer and the language is not English, prepend a [!WARNING] block stating that lossless parity cannot be guaranteed.

Output markdown only. No preamble, no explanation outside the document.

---

{source}"""


def transpile_claude(prompt: str) -> str:
    import anthropic
    model = os.environ.get("CLAUDE_MODEL", "claude-opus-4-6")
    client = anthropic.Anthropic()
    message = client.messages.create(
        model=model,
        max_tokens=8096,
        messages=[{"role": "user", "content": prompt}],
    )
    return message.content[0].text


def transpile_openai(prompt: str) -> str:
    from openai import OpenAI
    model = os.environ.get("OPENAI_MODEL", "gpt-4o")
    client = OpenAI()
    response = client.chat.completions.create(
        model=model,
        messages=[{"role": "user", "content": prompt}],
    )
    return response.choices[0].message.content


def transpile_gemini(prompt: str) -> str:
    from google import genai
    model = os.environ.get("GEMINI_MODEL", "gemini-2.0-flash")
    client = genai.Client(api_key=os.environ["GEMINI_API_KEY"])
    return client.models.generate_content(model=model, contents=prompt).text


PROVIDERS: dict[str, object] = {
    "claude": transpile_claude,
    "gemini": transpile_gemini,
    "openai": transpile_openai,
}

app = typer.Typer()


_default_source = Path(__file__).parent.parent / "machine.md"


@app.command()
def main(
    node_type: Annotated[NodeType, typer.Argument(help="Target node type")],
    lang: Annotated[str, typer.Argument(help="ISO 639-1/3 language code")],
    source: Annotated[Path, typer.Option(help="Path to machine.md")] = _default_source,
) -> None:
    if lang not in LANGUAGE_CODES:
        typer.echo(f"Unknown language '{lang}'. Codes: {', '.join(sorted(LANGUAGE_CODES))}", err=True)
        raise typer.Exit(code=1)

    if node_type is NodeType.newborn:
        typer.echo("N/A")
        return

    provider = os.environ.get("PROVIDER", DEFAULT_PROVIDER).lower()
    if provider not in PROVIDERS:
        typer.echo(f"Unknown provider '{provider}'. Choose from: {', '.join(PROVIDERS)}", err=True)
        raise typer.Exit(code=1)

    prompt = build_prompt(node_type, lang, source.read_text())
    typer.echo(PROVIDERS[provider](prompt))  # type: ignore[operator]


if __name__ == "__main__":
    app()

