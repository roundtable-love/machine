#! /usr/bin/env nix-shell
#! nix-shell -i python3 -p "python3.withPackages(pkgs: with pkgs; [pyyaml typer])"

"""Compile markdown source files to standards YAML.

Usage:
  compile [<source.md>|<dir>...]
  compile <source.md> <output.yaml>
  cat <source.md> | compile
"""

import re
import sys
from pathlib import Path
from typing import Annotated, Callable, Optional

import typer
import yaml

app = typer.Typer(help=__doc__)

_repo_root = Path(__file__).resolve().parents[2]

# ── YAML output ────────────────────────────────────────────────────────────────


def _dump(obj: dict) -> str:
    return yaml.dump(obj, allow_unicode=True, default_flow_style=False, sort_keys=False)


def _emit(obj: dict, out: Optional[Path]) -> None:
    text = _dump(obj)
    if out:
        out.write_text(text)
        typer.echo(f"→ {out}")
    else:
        sys.stdout.write(text)


# ── Providers ──────────────────────────────────────────────────────────────────
#
# Each provider is a callable (text, stem) -> Optional[dict].
# Providers are tried in order; first non-None result wins.


def _standard(text: str, stem: str) -> Optional[dict]:
    """Extract embedded YAML block containing a `standard:` document."""
    for block in re.findall(r"```ya?ml\n(.*?)```", text, re.DOTALL):
        parsed = yaml.safe_load(block)
        if isinstance(parsed, dict) and "standard" in parsed:
            return parsed
    return None


_UID_MAP = {
    "CAUSE-AND-EFFECT": "CE",
    "CORRESPONDENCE": "CO",
    "POLARITY": "P",
    "REFLECTION": "R",
    "RHYTHM": "RH",
    "TRUTH": "T",
    "UNITY": "U",
}


def _quotes(text: str, stem: str) -> Optional[dict]:
    """Extract or construct a `quotes` document from markdown."""
    # Embedded quotes YAML block takes priority.
    for block in re.findall(r"```ya?ml\n(.*?)```", text, re.DOTALL):
        parsed = yaml.safe_load(block)
        if isinstance(parsed, dict) and "quotes" in parsed:
            return parsed

    # Construct from markdown structure.
    h1 = re.search(r"^#\s+(.+)", text, re.MULTILINE)
    name = h1.group(1).strip() if h1 else stem.replace("-", " ").title()

    code = _UID_MAP.get(stem.upper(), stem.upper()[:2])
    uid = f"quotes-{code}"

    # machine_ir from fenced block under "## Machine IR" heading.
    machine_ir = ""
    ir_match = re.search(
        r"##\s+Machine IR\s*\n+```[a-z]*\n(.*?)```",
        text,
        re.DOTALL | re.IGNORECASE,
    )
    if ir_match:
        machine_ir = ir_match.group(1).strip()

    # sources from YAML block, or structured list items.
    sources: list = []
    src_yaml = re.search(
        r"##\s+Sources?\s*\n+```ya?ml\n(.*?)```",
        text,
        re.DOTALL | re.IGNORECASE,
    )
    if src_yaml:
        sources = yaml.safe_load(src_yaml.group(1)) or []
    else:
        for m in re.finditer(
            r"-\s+quote:\s*(.+?)\n\s+source:\s*(.+?)(?:\n\s+ref:\s*(\S+))?(?=\n-|\Z)",
            text,
            re.DOTALL,
        ):
            entry: dict = {"quote": m.group(1).strip(), "source": m.group(2).strip()}
            if m.group(3):
                entry["ref"] = m.group(3).strip()
            sources.append(entry)

    doc: dict = {
        "quotes": {
            "uid": uid,
            "name": name,
            "version": "1.0.0-IMMUTABLE",
            "base_class": "Universal_Law",
        }
    }
    if machine_ir:
        doc["quotes"]["machine_ir"] = machine_ir
    if sources:
        doc["sources"] = sources
    doc["metadata"] = {
        "custodian": "Universal",
        "status": "IMMUTABLE",
        "source": f"universal-law/{stem}.md",
    }
    return doc


_PROVIDERS: list[Callable[[str, str], Optional[dict]]] = [_standard, _quotes]


# ── Core ───────────────────────────────────────────────────────────────────────


def compile_text(text: str, stem: str, file_name: str, out: Optional[Path] = None) -> None:
    for provider in _PROVIDERS:
        doc = provider(text, stem)
        if doc is not None:
            _emit(doc, out)
            return
    typer.echo(f"warning: no provider matched {file_name}", err=True)


def compile(source: Path, out: Optional[Path] = None) -> None:
    compile_text(source.read_text(), source.stem, source.name, out)


# ── CLI ────────────────────────────────────────────────────────────────────────


@app.command()
def main(
    paths: Annotated[
        Optional[list[Path]],
        typer.Argument(help="Markdown files or directories"),
    ] = None,
    out_dir: Annotated[
        Path,
        typer.Option(help="Output directory for compiled YAML"),
    ] = _repo_root / "standards",
) -> None:
    if not paths:
        if not sys.stdin.isatty():
            text = sys.stdin.read()
            compile_text(text, "STDIN", "STDIN", None)
            return
        raise typer.BadParameter("provide files, directories, or pipe to stdin")

    # compile <source.md> <output.yaml>
    if len(paths) == 2 and not paths[1].is_dir() and paths[1].suffix == ".yaml":
        compile(paths[0], paths[1])
        return

    for p in paths:
        if p.is_dir():
            for md in sorted(p.glob("*.md")):
                compile(md, out_dir / (md.stem + ".yaml"))
        else:
            compile(p, out_dir / (p.stem + ".yaml"))


if __name__ == "__main__":
    app()

# vim:ft=python
